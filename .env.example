# Local development (Docker Postgres)
DATABASE_URL="postgresql://autocentre:autocentre@localhost:5433/autocentre?schema=public"

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-secure-random-string"
AUTH_SECRET="generate-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Seed script only — do not use weak passwords in production
ADMIN_EMAIL="admin@autogalaxy.in"
ADMIN_PASSWORD="change-me-in-production"

# Google Maps (Places Autocomplete + map on book-service & contact pages)
# Enable: Maps JavaScript API + Places API
# https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Production example (Neon / Supabase / Railway)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# NEXTAUTH_URL="https://your-domain.com"
