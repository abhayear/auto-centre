# Local development (Docker Postgres)
DATABASE_URL="postgresql://autocentre:autocentre@localhost:5432/autocentre?schema=public"

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-secure-random-string"
AUTH_SECRET="generate-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Seed script only — do not use weak passwords in production
ADMIN_EMAIL="admin@autocentre.com"
ADMIN_PASSWORD="change-me-in-production"

# Production example (Neon / Supabase / Railway)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# NEXTAUTH_URL="https://your-domain.com"
